{
    "mem0": {
        "llm": {
            "provider": "openai",
            "config": {
                "model": "mistral-medium-latest",
                "temperature": 0.1,
                "max_tokens": 2000,
                "api_key": "env:OPENAI_API_KEY"
            }
        },
        "embedder": {
            "provider": "huggingface",
            "config": {
                "model": "BAAI/bge-m3",
                "model_kwargs": {
                    "device": "cuda"
                },
                "embedding_dims": 1024
            }
        },
        "vector_store": {
            "provider": "qdrant",
            "config": {
                "collection_name": "openmemory",
                "url": "http://10.8.0.1:6333",
                "api_key": "123",
                "embedding_model_dims": 1024
            }
        }
    }
}
