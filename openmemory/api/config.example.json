{
  "mem0": {
    "llm": {
      "provider": "openai",
      "config": {
        "model": "mistral-medium-latest",
        "temperature": 0.1,
        "max_tokens": 2000,
        "api_key": "env:OPENAI_API_KEY"
      }
    },
    "embedder": {
      "provider": "openai",
      "config": {
        "model": "mistral-embed",
        "openai_base_url": "https://api.mistral.ai/v1",
        "api_key": "env:OPENAI_API_KEY",
        "embedding_dims": 1024
      }
    },
    "vector_store": {
      "provider": "qdrant",
      "config": {
        "collection_name": "openmemory",
        "url": "http://your-qdrant-host:6333",
        "api_key": "",
        "embedding_model_dims": 1024
      }
    }
  }
}
